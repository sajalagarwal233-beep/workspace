{
  "display_information": {
    "name": "OpenClaw",
    "description": "AI Assistant connector for OpenClaw - message your personal AI from Slack",
    "background_color": "#6366f1"
  },
  "features": {
    "bot_user": {
      "display_name": "OpenClaw",
      "always_online": false,
      "username": "openclaw"
    },
    "app_home": {
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "slash_commands": [
      {
        "command": "/openclaw",
        "description": "Chat with your AI assistant",
        "should_escape": false
      }
    ],
    "workflows": {
      "trigger_urls": []
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "chat:write",
        "channels:history",
        "channels:read",
        "groups:history",
        "im:history",
        "mpim:history",
        "users:read",
        "app_mentions:read",
        "assistant:write",
        "reactions:read",
        "reactions:write",
        "pins:read",
        "pins:write",
        "emoji:read",
        "commands",
        "files:read",
        "files:write"
      ]
    }
  },
  "settings": {
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false,
    "event_subscriptions": {
      "request_url": "",
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim",
        "reaction_added",
        "reaction_removed",
        "member_joined_channel",
        "member_left_channel",
        "channel_rename",
        "pin_added",
        "pin_removed"
      ]
    },
    "interactivity": {
      "request_url": "",
      "placeholder": ""
    },
    "capes": []
  }
}
