{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "OpenClaw",
    "description": "AI Assistant connector for OpenClaw - message your personal AI from Slack",
    "background_color": "#6366f1",
    "long_description": "Connect Slack to OpenClaw to chat with your personal AI assistant. Send messages, get AI responses, and automate workflows directly from Slack."
  },
  "features": {
    "bot_user": {
      "display_name": "OpenClaw",
      "always_online": false,
      "username": "openclaw"
    },
    "app_home": {
      "messages_tab_enabled": true,
      "home_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "slash_commands": [
      {
        "command": "/openclaw",
        "url": "",
        "description": "Chat with your AI assistant",
        "usage_hint": "your message",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [],
    "scopes": [
      {
        "scope": "bot",
        "tokens": {
          "xoxb": [
            "chat:write",
            "channels:history",
            "channels:read",
            "groups:history",
            "groups:read",
            "im:history",
            "im:read",
            "mpim:history",
            "mpim:read",
            "users:read",
            "app_mentions:read",
            "assistant:write",
            "reactions:read",
            "reactions:write",
            "pins:read",
            "pins:write",
            "emoji:read",
            "commands",
            "files:read",
            "files:write",
            "channels:join"
          ]
        }
      }
    ]
  },
  "settings": {
    "event_handlers": {
      "events": [
        {
          "event_type": "app_mention",
          "action_configuration": {
            "block_actions": null,
            "message_action_sources": null
          }
        },
        {
          "event_type": "message.channels",
          "action_configuration": null
        },
        {
          "event_type": "message.groups",
          "action_configuration": null
        },
        {
          "event_type": "message.im",
          "action_configuration": null
        },
        {
          "event_type": "message.mpim",
          "action_configuration": null
        },
        {
          "event_type": "reaction_added",
          "action_configuration": null
        },
        {
          "event_type": "reaction_removed",
          "action_configuration": null
        }
      ]
    },
    "socket_mode": {
      "enabled": true,
      "connect": true
    },
    "interactivity": {
      "enabled": true
    },
    "org_deploy_enabled": false,
    "token_rotation_enabled": false
  }
}
